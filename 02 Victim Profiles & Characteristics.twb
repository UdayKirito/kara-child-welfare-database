      <aliases enabled='yes' />
      <column caption='Screened In % (Recalc)' datatype='real' name='[Calculation_1193735419494051841]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([Total child maltreatment reports received]) = 0 THEN NULL&#13;&#10;ELSE SUM([Number of screened in reports]) / SUM([Total child maltreatment reports received])&#13;&#10;END' />
      </column>
      <column caption='Screened Out % (Recalc)' datatype='real' name='[Calculation_1193735419494219778]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([Total child maltreatment reports received]) = 0 THEN NULL&#13;&#10;ELSE SUM([Number of screened out reports]) / SUM([Total child maltreatment reports received])&#13;&#10;END' />
      </column>
      <column caption='Total Reports' datatype='integer' name='[Calculation_1193735419496120323]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total child maltreatment reports received])' />
      </column>
      <column caption='Rank by reports' datatype='integer' name='[Calculation_1193735419496218628]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(SUM([Total child maltreatment reports received]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Rank by Reports' datatype='integer' name='[Calculation_1193735419496321029]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(SUM([Total child maltreatment reports received]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Race Screened In % (Recalc)' datatype='real' name='[Calculation_1193735419498811399]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([Total reports received]) = 0 THEN NULL&#13;&#10;ELSE SUM([Screened in reports (N)]) / SUM([Total reports received])&#13;&#10;END' />
      </column>
      <column caption='Statewide Screened In % (LOD)' datatype='real' name='[Calculation_1193735419498917896]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Year] :&#13;&#10;    SUM([Screened in reports (N)]) / SUM([Total reports received])&#13;&#10;}' />
      </column>
      <column caption='Reporter Screened In % (Recalc)' datatype='real' name='[Calculation_1193735419500064779]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([Total reports received]) = 0 THEN NULL&#13;&#10;ELSE SUM([Screened in reports (N)]) / SUM([Total reports received])&#13;&#10;END' />
      </column>
      <column caption='Reporter Share %' datatype='real' name='[Calculation_1193735419500195852]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total reports received]) / &#13;&#10;WINDOW_SUM(SUM([Total reports received]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Screen Out % (from sheet)' datatype='real' name='[Calculation_1193735419500994573]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Percent of each reason])' />
      </column>
      <column caption='Victims (Count)' datatype='integer' name='[Calculation_1193735419501154318]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Number of Victims Abused or neglected])' />
      </column>
      <column caption='Abuse/Neglect Rate (per 1,000)' datatype='real' name='[Calculation_1193735419501264911]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Rate of abuse or neglect])' />
      </column>
      <column caption='Reporter Type (Cleaned)' datatype='string' name='[Calculation_1193735419515170833]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS(LOWER([Reporter type]), &quot;non&quot;) THEN &quot;Non-mandated&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([Reporter type]), &quot;mandated&quot;) THEN &quot;Mandated&quot;&#13;&#10;ELSE &quot;Unknown/Other&quot;&#13;&#10;END' />
        <aliases>
          <alias key='&quot;Mandated&quot;' value='Mandated Reporters (Professionals required by law)' />
          <alias key='&quot;Non-mandated&quot;' value='Non-mandated Reporters (Community / Family)' />
