            <column caption='% Confirmed Victims' datatype='real' name='[Calculation_1449596173695950848]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([Alleged victims]) = 0 THEN NULL&#13;&#10;ELSE SUM([Determined victims]) / SUM([Alleged victims])&#13;&#10;END' />
